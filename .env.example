# Optional. If set, enables Google Places website links + cover photos.
# Uses the Places JS SDK (browser-legal, no server needed).
VITE_GOOGLE_PLACES_KEY=

# Optional. data.cms.gov's Provider Data Catalog API sends no CORS headers,
# so requests to it are relayed through a proxy (defaults to a public relay,
# api.allorigins.win). Point this at your own proxy once you have one — it
# should accept ?url=<encoded target> and return the body with CORS headers.
VITE_CMS_PROXY_BASE=
